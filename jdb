#!/bin/bash

# Handle "jdb", "jdb help", "jdb --help" — print jdb-specific blurb then adb help.
if [[ $# -eq 0 || "$1" == "help" || "$1" == "--help" ]]; then
    cat <<'EOF'
jdb — adb wrapper that resolves mDNS friendly names and picks a device when
more than one is attached.

jdb-specific behavior:
  jdb devices                 adb devices, annotated with friendly names
  jdb connect NAME[:PORT]...  connect to one or more devices by friendly name
                              (port defaults to 4242)
  jdb disconnect [NAME]       resolve NAME via mDNS; bare form disconnects all
  jdb -s NAME[:PORT] ...      -s argument is resolved via mDNS

When multiple devices are attached and -s is not given, jdb prompts to pick
one via adb-pick-device. Names without an alias are tried as <name>.local;
IP literals and unresolvable inputs pass through unchanged.

All other arguments are forwarded to adb. adb usage follows.
----
EOF
    exec adb help
fi

# Handle "jdb devices" — annotate with mDNS reverse mapping
if [[ "$1" == "devices" ]]; then
    declare -A ip_to_name
    while IFS=$'\t' read -r ip label; do
        [[ -n "$ip" ]] && ip_to_name["$ip"]="$label"
    done < <(mdns-resolve reverse-map)

    adb devices "${@:2}" | while IFS= read -r line; do
        if [[ "$line" =~ ^([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+):[0-9]+[[:space:]] ]]; then
            ip="${BASH_REMATCH[1]}"
            if [[ -n "${ip_to_name[$ip]}" ]]; then
                # label is "name (mdnshost)" — split into name and mdns part
                name="${ip_to_name[$ip]%% (*}"
                mdns="${ip_to_name[$ip]#* }"
                printf '%s\t%s\t%s\n' "$name" "$line" "$mdns"
                continue
            fi
        fi
        echo "$line"
    done
    exit
fi

# Resolve "name[:port]" → "ip:port" (defaults to 4242)
resolve_with_port() {
    local input="$1" name="$1" port=4242
    if [[ "$input" == *:* ]]; then
        name="${input%%:*}"
        port="${input##*:}"
    fi
    printf '%s:%s\n' "$(mdns-resolve "$name")" "$port"
}

# A Neat serial looks like two letters + digits, e.g. NB12249000245.
SERIAL_RE='^[A-Za-z]{2}[0-9]{8,}$'

# verify_serial <name> <ip:port> — after connecting, confirm the device really
# is the one we asked for; a stale/wrong mDNS or Pulse IP could point elsewhere.
# `getprop` prints lines like "[ro.serialno]: [NB12249000245]", so we look for
# the expected serial bracketed in any property (works whatever ro.* holds it).
# On mismatch (or an unreadable/unauthorized device) we disconnect and fail.
# Returns 0 — connection kept — when there's no serial to check against
# (IP literals, plain mDNS hostnames that aren't serials).
verify_serial() {
    local name="${1%%:*}" target="$2" expected props got i
    expected="$(mdns-resolve host "$name" 2>/dev/null)"; expected="${expected%.local}"
    [[ -z "$expected" && "$name" =~ $SERIAL_RE ]] && expected="$name"
    [[ -n "$expected" ]] || return 0

    # Give the freshly-connected device a moment to come online.
    for i in 1 2 3 4 5 6; do
        [[ "$(adb -s "$target" get-state 2>/dev/null)" == "device" ]] && break
        sleep 0.5
    done

    props="$(adb -s "$target" shell getprop 2>/dev/null | tr -d '\r')"

    # Right device: the expected serial appears bracketed in some property. Neat
    # devices expose it several ways (ro.serialno, ro.boot.serialno, …), so a
    # legitimate device always matches. Case-insensitive so an alias table whose
    # serial casing differs from ro.serialno doesn't wrongly drop a valid device.
    if printf '%s' "$props" | grep -iqF "[$expected]"; then
        return 0
    fi

    # Anything else — a different device, or one we can't read (offline /
    # unauthorized) — is unverified, so disconnect.
    got="$(printf '%s\n' "$props" | sed -nE 's/^\[ro\.(boot\.)?serialno\]: \[(.*)\]$/\2/p' | head -1)"
    echo "jdb: serial check failed for '$name' ($target): expected $expected, got ${got:-<unreadable>} — disconnecting" >&2
    adb disconnect "$target" >/dev/null 2>&1
    return 1
}

args=()
has_s=0
for arg in "$@"; do
    if [[ "$prev" == "-s" ]]; then
        arg=$(resolve_with_port "$arg")
        has_s=1
    fi
    prev="$arg"
    args+=("$arg")
done

# Handle "jdb connect <name> [<name> ...]"
if [[ "${args[0]}" == "connect" ]]; then
    status=0
    for name in "${args[@]:1}"; do
        target="$(resolve_with_port "$name")"
        if ! adb connect "$target"; then status=$?; continue; fi
        verify_serial "$name" "$target" || status=1
    done
    exit "$status"
fi

# Handle "jdb disconnect <name>" — bare "jdb disconnect" still disconnects all.
if [[ "${args[0]}" == "disconnect" && -n "${args[1]:-}" ]]; then
    exec adb disconnect "$(resolve_with_port "${args[1]}")"
fi

# First positional arg (the adb subcommand), skipping flags and their values.
subcmd=""
skip_next=0
for a in "${args[@]}"; do
    if (( skip_next )); then skip_next=0; continue; fi
    case "$a" in
        -s|-H|-P|-L|-t) skip_next=1; continue ;;
        -*) continue ;;
    esac
    subcmd="$a"
    break
done

# Subcommands that don't operate on a single device — pass through unchanged.
case "$subcmd" in
    start-server|kill-server|version|--version|pair|disconnect|reconnect|mdns)
        exec adb "${args[@]}"
        ;;
esac

# Inject -s when multiple devices are connected and the user didn't pick one.
if (( !has_s )); then
    count=$(adb devices 2>/dev/null | awk -F'\t' 'NR>1 && $2=="device"' | wc -l)
    if (( count > 1 )); then
        serial=$(adb-pick-device) || exit
        args=(-s "$serial" "${args[@]}")
    fi
fi

exec adb "${args[@]}"
