#!/bin/bash

# Handle "jdb devices" — annotate with mDNS reverse mapping
if [[ "$1" == "devices" ]]; then
    declare -A ip_to_name
    while IFS=$'\t' read -r ip label; do
        [[ -n "$ip" ]] && ip_to_name["$ip"]="$label"
    done < <(mdns-resolve reverse-map)

    adb devices "${@:2}" | while IFS= read -r line; do
        if [[ "$line" =~ ^([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+):[0-9]+[[:space:]] ]]; then
            ip="${BASH_REMATCH[1]}"
            if [[ -n "${ip_to_name[$ip]}" ]]; then
                # label is "name (mdnshost)" — split into name and mdns part
                name="${ip_to_name[$ip]%% (*}"
                mdns="${ip_to_name[$ip]#* }"
                printf '%s\t%s\t%s\n' "$name" "$line" "$mdns"
                continue
            fi
        fi
        echo "$line"
    done
    exit
fi

# Resolve "name[:port]" → "ip:port" (defaults to 4242)
resolve_with_port() {
    local input="$1" name="$1" port=4242 ip
    if [[ "$input" == *:* ]]; then
        name="${input%%:*}"
        port="${input##*:}"
    fi
    ip=$(mdns-resolve "$name") || { echo "jdb: could not resolve '$name'" >&2; return 1; }
    printf '%s:%s\n' "$ip" "$port"
}

args=()
for arg in "$@"; do
    if [[ "$prev" == "-s" ]]; then
        arg=$(resolve_with_port "$arg") || exit 1
    fi
    prev="$arg"
    args+=("$arg")
done

# Handle "jdb connect <name>"
if [[ "${args[0]}" == "connect" ]]; then
    target=$(resolve_with_port "${args[1]}") || exit 1
    exec adb connect "$target"
fi

exec adb "${args[@]}"
