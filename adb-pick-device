#!/bin/bash

# Print the serial of the adb device to act on.
# - 1 device: print its serial.
# - >1 devices: prompt the user via /dev/tty and print the chosen serial.
# - 0 devices: error and exit non-zero.

declare -A ip_to_name
while IFS=$'\t' read -r ip label; do
    [[ -n "$ip" ]] && ip_to_name["$ip"]="$label"
done < <(mdns-resolve reverse-map)

serials=()
labels=()
while IFS=$'\t' read -r serial state _; do
    [[ -z "$serial" || "$serial" == "List of devices attached" ]] && continue
    [[ "$state" == "device" ]] || continue
    serials+=("$serial")
    label=""
    if [[ "$serial" =~ ^([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+):[0-9]+ ]]; then
        ip="${BASH_REMATCH[1]}"
        label="${ip_to_name[$ip]%% (*}"
    fi
    labels+=("$label")
done < <(adb devices)

n=${#serials[@]}
if (( n == 0 )); then
    echo "adb-pick-device: no devices connected" >&2
    exit 1
fi
if (( n == 1 )); then
    printf '%s\n' "${serials[0]}"
    exit 0
fi

if [[ ! -r /dev/tty || ! -w /dev/tty ]]; then
    echo "adb-pick-device: multiple devices connected and no tty for prompting" >&2
    exit 1
fi

draw_line() {
    local i=$1 marker='  ' on='' off=''
    if (( i == cursor )); then
        marker='> '
        on=$'\e[7m'
        off=$'\e[0m'
    fi
    if [[ -n "${labels[i]}" ]]; then
        printf '%s%s%d) %-20s  %s%s\n' "$marker" "$on" $((i+1)) "${labels[i]}" "${serials[i]}" "$off"
    else
        printf '%s%s%d) %s%s\n' "$marker" "$on" $((i+1)) "${serials[i]}" "$off"
    fi
}

print_menu() {
    local i
    for ((i=0; i<n; i++)); do
        draw_line "$i"
    done
    printf '[Up/Down to move, Enter to select, 1-%d to jump, q to cancel]\n' "$n"
}

cursor=0

{
    echo "Multiple devices connected:"
    print_menu
} > /dev/tty

old_stty=$(stty -g < /dev/tty)
trap 'stty "$old_stty" < /dev/tty' EXIT
stty -echo -icanon < /dev/tty

redraw() {
    printf '\e[%dA\e[J' $((n+1)) > /dev/tty
    print_menu > /dev/tty
}

while :; do
    IFS= read -rsn1 c < /dev/tty
    case "$c" in
        $'\x1b')
            IFS= read -rsn2 -t 0.1 rest < /dev/tty
            case "$rest" in
                '[A'|'OA') (( cursor > 0 )) && cursor=$((cursor-1)) ;;
                '[B'|'OB') (( cursor < n-1 )) && cursor=$((cursor+1)) ;;
                '[H'|'OH') cursor=0 ;;
                '[F'|'OF') cursor=$((n-1)) ;;
                '') exit 1 ;;
            esac
            redraw
            ;;
        '')
            printf '%s\n' "${serials[$cursor]}"
            exit 0
            ;;
        [1-9])
            if (( c <= n )); then
                cursor=$((c-1))
                redraw
                printf '%s\n' "${serials[$cursor]}"
                exit 0
            fi
            ;;
        q)
            exit 1
            ;;
    esac
done
